# ==========================================
# Online Complaint Resolution System - Frontend
# Environment Variables Configuration
# ==========================================

# ==========================================
# API CONFIGURATION
# ==========================================
# Backend API URL for development
VITE_API_URL=http://localhost:6969

# Backend API URL for production
# VITE_API_URL=https://api.complaintresolution.gov

# ==========================================
# APPLICATION NAME & VERSION
# ==========================================
VITE_APP_NAME=Online Complaint Resolution System
VITE_APP_VERSION=1.0.0

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable/disable features during development
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_LOCATION_SERVICES=true
VITE_ENABLE_FILE_UPLOADS=true

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Google Maps API Key for location services
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log level for frontend: error, warn, info, debug
VITE_LOG_LEVEL=debug

# ==========================================
# TIMEOUTS & LIMITS
# ==========================================
# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# Maximum file upload size in MB
VITE_MAX_FILE_SIZE=10

# ==========================================
# THEME CONFIGURATION
# ==========================================
# Default theme: light or dark
VITE_DEFAULT_THEME=light

# ==========================================
# PAGINATION
# ==========================================
# Default items per page
VITE_DEFAULT_PAGE_SIZE=10

# ==========================================
# AUTHENTICATION
# ==========================================
# Token storage method: localStorage or sessionStorage
VITE_TOKEN_STORAGE=localStorage

# Token cookie name
VITE_TOKEN_COOKIE_NAME=auth_token

# ==========================================
# BUILD CONFIGURATION
# ==========================================
# Source map generation for production
VITE_SOURCEMAP=true
