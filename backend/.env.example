# ==========================================
# Online Complaint Resolution System - Backend
# Environment Variables Configuration
# ==========================================

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/complaint_system_db

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Secret key for JWT token signing (min 32 characters)
# Generate: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_32_chars_min
JWT_EXPIRY=24
REFRESH_TOKEN_EXPIRY=7

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# SMTP Configuration for Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@complaintresolution.gov
EMAIL_FROM_NAME=Complaint Resolution System
SUPPORT_EMAIL=support@complaintresolution.gov

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
# Maximum file upload size (in MB)
MAX_FILE_SIZE=10
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ==========================================
# CORS CONFIGURATION
# ==========================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# SLA CONFIGURATION (in hours)
# ==========================================
SLA_LOW=168
SLA_MEDIUM=72
SLA_HIGH=24
SLA_CRITICAL=4

# ==========================================
# CRON JOB CONFIGURATION
# ==========================================
ENABLE_SLA_JOBS=true
SLA_CHECK_SCHEDULE=0 */6 * * *

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=your_session_secret_key_change_in_production

# ==========================================
# SECURITY
# ==========================================
BCRYPT_SALT_ROUNDS=10

# ==========================================
# PAGINATION
# ==========================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ==========================================
# NOTIFICATIONS
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_DASHBOARD_NOTIFICATIONS=true

# ==========================================
# EXTERNAL SERVICES (Optional)
# ==========================================
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# SENTRY_DSN=your_sentry_dsn_url
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=complaint-uploads
